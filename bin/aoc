#!/usr/bin/env bash
set -euo pipefail
shopt -s extglob

YEAR="$(date +%y)"
DAY="$(date +%d)"
DAY="${DAY##+(0)}"
HOUR="$(date +%H)"
HOUR="${HOUR##+(0)}"

# AoC comes out of 10p MST, so we account for TZ offset
# Assuming that it's after 9p MST, we are working the
# next day
if (( HOUR >= 21 )); then
    DAY=$(( DAY + 1 ))
fi

FNAME="input"
MODE="run"
while getopts ":bted:y:" opt; do
    case $opt in
        b)
            MODE="bench"
            ;;
        t)
            MODE="test"
            ;;
        e)
            FNAME="example"
            ;;
        d)
            DAY="$OPTARG"
            ;;
        y)
            YEAR="$OPTARG"
            ;;
        \?)
            echo "Unknown option"
            exit 1
            ;;
    esac

done

DAY_FNAME="$(printf '%02d' "$DAY")"

PKG="aoc$YEAR"
case "$MODE" in
    bench)
        cargo bench -p "$PKG" "day$DAY_FNAME"
        ;;
    test)
        cargo test -p "$PKG" "day$DAY_FNAME"
        ;;
    run)
        cargo run --release -p "$PKG" "$DAY" < "$PKG/inputs/day$DAY_FNAME.$FNAME.txt"
        ;;
esac
